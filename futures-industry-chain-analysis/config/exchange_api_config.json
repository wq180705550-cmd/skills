            "data_format": "csv",
            "update_frequency": "daily",
            "requires_auth": false,
            "rate_limit": "unknown",
            "notes": "股指期货、国债期货日线数据"
        },
        "GFEX": {
            "name": "广州期货交易所",
            "api_type": "official",
            "base_url": "http://www.gfex.com.cn",
            "endpoints": {
                "daily_data": "/gfex/rihq/{date}.js"

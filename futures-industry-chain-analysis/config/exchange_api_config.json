            "rate_limit": "unknown",
            "notes": "免费开放，支持日周月行情、合约参数、仓单、持仓统计"
        },
        "SHFE": {
            "name": "上海期货交易所",
            "api_type": "official",
            "base_url": "http://www.shfe.com.cn",
            "endpoints": {
                "daily_data": "/data/dailydata/kx/kx{date}.dat"
            },
            "data_format": "json",
            "update_frequency": "daily",
            "requires_auth": false,
            "rate_limit": "unknown",
            "notes": "JSON格式，数据结构清晰，包含成交额字段"
        },
        "CZCE": {
            "name": "郑州商品交易所",
            "api_type": "official",
            "base_url": "http://www.czce.com.cn",
            "endpoints": {
                "daily_data_new": "/cn/DFSStaticFiles/Future/{year}/{date}/FutureDataDaily.htm",
                "daily_data_old": "/cn/exchange/{year}/datadaily/{date}.htm"
            },
            "data_format": "html",
            "update_frequency": "daily",
            "requires_auth": false,
            "rate_limit": "unknown",
            "notes": "2015年11月11日前后接口切换，HTML格式需要解析"
        },
        "CFFEX": {
            "name": "中国金融期货交易所",
            "api_type": "official",
            "base_url": "http://www.cffex.com.cn",

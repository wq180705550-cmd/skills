    "data_fields": {
        "symbol": "合约代码",
        "trade_date": "交易日期",
        "open": "开盘价",
        "high": "最高价",
        "low": "最低价",
        "close": "收盘价",
        "settle": "结算价",
        "volume": "成交量",
        "open_interest": "持仓量",
        "turnover": "成交额"
    },
    "usage_notes": {
        "priority": "交易所官方API > AKShare > TqSdk > 通达信MCP",
        "compliance": "交易所官方数据无爬虫合规风险，最权威",
        "limitations": "仅支持日频数据，无实时Tick",

#!/usr/bin/env python3
"""
wb-hook CLI — WorkBuddy Hook System 命令行工具
支持 init/add/list/remove/test/run 子命令
"""

import sys
import os
import json
import yaml
import subprocess
from pathlib import Path

# 默认配置路径
DEFAULT_CONFIG_DIR = Path(".claude-hooks")
DEFAULT_CONFIG_FILE = DEFAULT_CONFIG_DIR / "hooks.yaml"

def load_config():
    """加载 hooks.yaml 配置"""
    if not DEFAULT_CONFIG_FILE.exists():
        return {"hooks": {}}
    with open(DEFAULT_CONFIG_FILE, "r", encoding="utf-8") as f:
        return yaml.safe_load(f) or {"hooks": {}}

def save_config(config):
    """保存 hooks.yaml 配置"""
    DEFAULT_CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    with open(DEFAULT_CONFIG_FILE, "w", encoding="utf-8") as f:
        yaml.dump(config, f, allow_unicode=True, default_flow_style=False)

def cmd_init(args):
    """初始化 hook 系统"""
    print("[wb-hook] 初始化 hook 系统...")
    
    # 创建目录结构
    dirs = [
        DEFAULT_CONFIG_DIR,
        DEFAULT_CONFIG_DIR / "hooks",
        DEFAULT_CONFIG_DIR / "logs",
        DEFAULT_CONFIG_DIR / "scripts"
    ]
    for d in dirs:
        d.mkdir(parents=True, exist_ok=True)
        print(f"  ✓ 创建目录：{d}")
    
    # 创建默认 hooks.yaml
    default_config = {
        "hooks": {
            "PreToolUse": [
                {
                    "matcher": "Write|Edit",
                    "command": f"python {DEFAULT_CONFIG_DIR / 'hooks/pre_write.py'}",
                    "timeout": 3000,
                    "on_error": "allow"
                }
            ],
            "PostToolUse": [
                {
                    "matcher": "Read",
                    "command": f"python {DEFAULT_CONFIG_DIR / 'hooks/post_read.py'}",
                    "timeout": 1000
                }
            ],
            "Stop": [
                {
                    "matcher": "*",
                    "command": f"python {DEFAULT_CONFIG_DIR / 'hooks/stop_cleanup.py'}",
                    "timeout": 5000
                }
            ]
        }
    }
    save_config(default_config)
    print(f"  ✓ 创建配置文件：{DEFAULT_CONFIG_FILE}")
    
    # 创建示例 hook 脚本
    example_scripts = {
        "pre_write.py": '''#!/usr/bin/env python3
import sys
import json

event = json.load(sys.stdin)
params = event.get("params", {})
file_path = params.get("file_path", "")

# 禁止写入 node_modules
if "node_modules" in file_path:
    print(json.dumps({"decision": "block", "reason": f"❌ 禁止写入 node_modules：{file_path}"}))
    sys.exit(0)

# 禁止修改敏感文件
sensitive = [".env", ".env.local", "id_rsa", "id_ed25519"]
if any(s in file_path for s in sensitive):
    print(json.dumps({"decision": "block", "reason": f"❌ 禁止修改敏感文件：{file_path}"}))
    sys.exit(0)

print(json.dumps({"decision": "allow"}))
sys.exit(0)
''',
        "pre_bash.py": '''#!/usr/bin/env python3
import sys
import json
import re

event = json.load(sys.stdin)
params = event.get("params", {})
command = params.get("command", "")

# 危险命令检测
dangerous = [
    r"rm\s+-rf\s+/",
    r"git\s+push\s+--force",
    r"git\s+reset\s+--hard"
]
for pattern in dangerous:
    if re.search(pattern, command, re.IGNORECASE):
        print(json.dumps({"decision": "block", "reason": f"❌ 危险命令被阻断：{command[:50]}..."}))
        sys.exit(0)

print(json.dumps({"decision": "allow"}))
sys.exit(0)
''',
        "post_read.py": '''#!/usr/bin/env python3
import sys
import json
import time

event = json.load(sys.stdin)

log_entry = {
    "timestamp": time.time(),
    "event": "PostToolUse",
    "tool": event.get("tool"),
    "file_path": event.get("params", {}).get("file_path"),
    "status": event.get("result", {}).get("status")
}

# 写入日志
log_dir = ".claude-hooks/logs"
os.makedirs(log_dir, exist_ok=True)
with open(f"{log_dir}/hook.log", "a", encoding="utf-8") as f:
    f.write(json.dumps(log_entry, ensure_ascii=False) + "\\n")

print(f"[LOG] Read {log_entry['file_path']}")
sys.exit(0)
''',
        "stop_cleanup.py": '''#!/usr/bin/env python3
import sys
import json
import os
import glob

event = json.load(sys.stdin)

# 清理临时文件
temp_patterns = ["**/*.tmp", "**/__pycache__", "**/*.pyc", "**/.DS_Store"]
cleaned = 0

for pattern in temp_patterns:
    for file in glob.glob(pattern, recursive=True):
        try:
            if os.path.isfile(file):
                os.remove(file)
                cleaned += 1
        except:
            pass

print(f"[STOP] 清理了 {cleaned} 个临时文件")
sys.exit(0)
'''
    }
    
    for name, content in example_scripts.items():
        script_path = DEFAULT_CONFIG_DIR / "hooks" / name
        with open(script_path, "w", encoding="utf-8") as f:
            f.write(content)
        script_path.chmod(0o755)
        print(f"  ✓ 创建示例脚本：{script_path}")
    
    print("\\n✅ Hook 系统初始化完成！")
    print(f"\\n下一步：")
    print(f"  1. 查看配置：cat {DEFAULT_CONFIG_FILE}")
    print(f"  2. 测试 hook：wb-hook test PreToolUse Write --params '{{\\"file_path\\":\\"node_modules/test.js\\"}}'")
    print(f"  3. 列出 hooks：wb-hook list")

def cmd_add(args):
    """添加 hook"""
    if len(args) < 3:
        print("用法：wb-hook add <event> <matcher> --command <cmd> [--timeout <ms>] [--on_error <allow|block>]")
        sys.exit(1)
    
    event = args[0]
    matcher = args[1]
    
    # 解析参数
    command = None
    timeout = 3000
    on_error = "allow"
    
    i = 2
    while i < len(args):
        if args[i] == "--command" and i + 1 < len(args):
            command = args[i + 1]
            i += 2
        elif args[i] == "--timeout" and i + 1 < len(args):
            timeout = int(args[i + 1])
            i += 2
        elif args[i] == "--on_error" and i + 1 < len(args):
            on_error = args[i + 1]
            i += 2
        else:
            i += 1
    
    if not command:
        print("错误：必须指定 --command")
        sys.exit(1)
    
    # 加载配置
    config = load_config()
    
    # 添加 hook
    if event not in config["hooks"]:
        config["hooks"][event] = []
    
    new_hook = {
        "matcher": matcher,
        "command": command,
        "timeout": timeout
    }
    if on_error != "allow":
        new_hook["on_error"] = on_error
    
    config["hooks"][event].append(new_hook)
    
    # 保存配置
    save_config(config)
    
    print(f"✅ 已添加 hook：{event} / {matcher} → {command}")

def cmd_list(args):
    """列出所有 hooks"""
    config = load_config()
    
    if not config["hooks"]:
        print("没有已注册的 hooks。")
        return
    
    print("📋 Hook 列表：\\n")
    
    for event, hooks in config["hooks"].items():
        print(f"  【{event}】")
        for i, hook in enumerate(hooks):
            matcher = hook.get("matcher", "")
            command = hook.get("command", "")
            timeout = hook.get("timeout", 3000)
            on_error = hook.get("on_error", "allow")
            
            print(f"    [{i+1}] matcher: {matcher}")
            print(f"         command: {command}")
            print(f"         timeout: {timeout}ms, on_error: {on_error}")
        print()

def cmd_remove(args):
    """删除 hook"""
    if len(args) < 2:
        print("用法：wb-hook remove <event> <matcher>")
        sys.exit(1)
    
    event = args[0]
    matcher = args[1]
    
    # 加载配置
    config = load_config()
    
    if event not in config["hooks"]:
        print(f"错误：事件 {event} 不存在")
        sys.exit(1)
    
    # 查找并删除 hook
    original_count = len(config["hooks"][event])
    config["hooks"][event] = [h for h in config["hooks"][event] if h.get("matcher") != matcher]
    
    if len(config["hooks"][event]) == original_count:
        print(f"错误：未找到 matcher={matcher} 的 hook")
        sys.exit(1)
    
    # 保存配置
    save_config(config)
    
    print(f"✅ 已删除 hook：{event} / {matcher}")

def cmd_test(args):
    """测试 hook（不实际执行工具）"""
    if len(args) < 2:
        print("用法：wb-hook test <event> <tool> [--params <json>]")
        sys.exit(1)
    
    event = args[0]
    tool = args[1]
    
    # 解析参数
    params = {}
    if "--params" in args:
        idx = args.index("--params")
        if idx + 1 < len(args):
            params = json.loads(args[idx + 1])
    
    # 构造事件 JSON
    event_json = {
        "event": event,
        "tool": tool,
        "params": params,
        "session_id": "test-session",
        "timestamp": time.time()
    }
    
    # 加载配置
    config = load_config()
    
    if event not in config["hooks"]:
        print(f"错误：事件 {event} 没有注册的 hooks")
        sys.exit(1)
    
    # 执行匹配的 hooks
    print(f"🧪 测试 {event}/{tool}...\\n")
    
    for hook in config["hooks"][event]:
        matcher = hook.get("matcher", "")
        
        # 检查是否匹配
        if matcher == "*" or matcher == tool or re.search(matcher, tool):
            command = hook.get("command", "")
            timeout = hook.get("timeout", 3000)
            
            print(f"  ▶ 执行 hook：{matcher} → {command}")
            
            try:
                result = subprocess.run(
                    command,
                    input=json.dumps(event_json),
                    capture_output=True,
                    text=True,
                    timeout=timeout / 1000.0
                )
                
                decision = json.loads(result.stdout)
                print(f"    决策：{decision['decision']}")
                if decision.get("reason"):
                    print(f"    原因：{decision['reason']}")
                
                if decision["decision"] == "block":
                    print(f"\\n❌ Hook 阻断！操作已取消。")
                    return
            except subprocess.TimeoutExpired:
                print(f"    ⚠️ Hook 超时（{timeout}ms），使用 on_error 决策")
            except Exception as e:
                print(f"    ⚠️ Hook 执行失败：{e}")
    
    print(f"\\n✅ 所有 hooks 通过，操作被允许。")

def cmd_run(args):
    """手动触发 hook（用于调试）"""
    if len(args) < 1:
        print("用法：wb-hook run <event> [--tool <tool>] [--params <json>]")
        sys.exit(1)
    
    event = args[0]
    
    # 解析参数
    tool = None
    params = {}
    
    if "--tool" in args:
        idx = args.index("--tool")
        if idx + 1 < len(args):
            tool = args[idx + 1]
    
    if "--params" in args:
        idx = args.index("--params")
        if idx + 1 < len(args):
            params = json.loads(args[idx + 1])
    
    # 构造事件 JSON
    event_json = {
        "event": event,
        "tool": tool,
        "params": params,
        "session_id": "manual-run",
        "timestamp": time.time()
    }
    
    print(f"🚀 手动触发 {event} hook...\\n")
    print(f"事件 JSON：{json.dumps(event_json, ensure_ascii=False, indent=2)}\\n")
    
    # 加载配置并执行
    config = load_config()
    
    if event not in config["hooks"]:
        print(f"错误：事件 {event} 没有注册的 hooks")
        sys.exit(1)
    
    for hook in config["hooks"][event]:
        matcher = hook.get("matcher", "")
        command = hook.get("command", "")
        
        if matcher == "*" or not tool or matcher == tool or (tool and re.search(matcher, tool)):
            print(f"  ▶ 执行：{command}")
            
            result = subprocess.run(
                command,
                input=json.dumps(event_json),
                capture_output=True,
                text=True
            )
            
            print(f"    输出：{result.stdout}")
            if result.stderr:
                print(f"    错误：{result.stderr}")

def print_usage():
    """打印使用说明"""
    print('''wb-hook — WorkBuddy Hook System CLI

用法：
  wb-hook init                          初始化 hook 系统
  wb-hook add <event> <matcher> --command <cmd>  添加 hook
  wb-hook list                          列出所有 hooks
  wb-hook remove <event> <matcher>      删除 hook
  wb-hook test <event> <tool> [--params <json>]  测试 hook
  wb-hook run <event> [--tool <tool>] [--params <json>]  手动触发

事件类型：
  PreToolUse   工具调用前（可阻断）
  PostToolUse  工具调用后（记录）
  Stop         会话结束（清理）

示例：
  wb-hook init
  wb-hook add PreToolUse "Write|Edit" --command "python .claude-hooks/hooks/pre_write.py"
  wb-hook test PreToolUse Write --params '{"file_path":"node_modules/test.js"}'
  wb-hook list
  wb-hook remove PreToolUse Write
''')

def main():
    """主入口"""
    if len(sys.argv) < 2:
        print_usage()
        sys.exit(1)
    
    subcommand = sys.argv[1]
    args = sys.argv[2:]
    
    if subcommand == "init":
        cmd_init(args)
    elif subcommand == "add":
        cmd_add(args)
    elif subcommand == "list":
        cmd_list(args)
    elif subcommand == "remove":
        cmd_remove(args)
    elif subcommand == "test":
        cmd_test(args)
    elif subcommand == "run":
        cmd_run(args)
    else:
        print(f"错误：未知子命令 '{subcommand}'")
        print_usage()
        sys.exit(1)

if __name__ == "__main__":
    main()
